# Copier ce fichier en .env et remplir les valeurs

# JWT — générer avec : openssl rand -base64 64
TASKLY_JWT_SECRET=

# Base de données
POSTGRES_PASSWORD=

# Mail (optionnel)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@taskly.app

# CORS
TASKLY_CORS_ALLOWED_ORIGINS=http://localhost:4201
