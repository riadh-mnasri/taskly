{
  "outputDirectory": "dist/taskly/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://taskly-backend-4nh4.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "experimentalServices": {
    "web": {
      "routePrefix": "/",
      "framework": "angular"
    }
  }
}
